{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/.venv/bin/python"
        },
        {
            "name": "Launch MD-GEN Sample Run",
            "type": "debugpy",
            "request": "launch",
            "module": "md_gen.cli",
            "args": [
                "--source", "C:\\Users\\claud\\Development\\test\\source",
                "--output", "C:\\Users\\claud\\Development\\test\\output",
                "--overwrite"
            ],
            "console": "integratedTerminal"
        },
        {
            "name": "Launch MD-MRG Sample Planner Run",
            "type": "debugpy",
            "request": "launch",
            "module": "md_mrg.cli",
            "args": [
                "--plan",
                "--source", "C:\\Users\\claud\\Development\\test\\output"
            ],
            "console": "integratedTerminal"
        },
        {
            "name": "Launch Webapp Backend",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "webapp.backend.app:app",
                "--reload",
                "--port", "8000"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        }
    ]
}