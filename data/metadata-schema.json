{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Dir2MdMetadata",
  "description": "Unified schema supporting per-document metadata and merge batch artifacts.",
  "oneOf": [
    { "$ref": "#/$defs/document" },
    { "$ref": "#/$defs/batch" }
  ],
  "$defs": {
    "fragment": {
      "type": "object",
      "required": ["sequence_number", "image_file", "markdown_file"],
      "properties": {
        "sequence_number": {
          "type": "integer",
          "minimum": 1
        },
        "image_file": {
          "type": "string"
        },
        "markdown_file": {
          "type": "string"
        },
        "anchors": {
          "type": "object",
          "properties": {
            "first_line": { "type": "string" },
            "last_line": { "type": "string" },
            "page_header": { "type": "string" },
            "page_footer": { "type": "string" }
          },
          "additionalProperties": true
        },
        "content_fingerprint": {
          "type": "object",
          "properties": {
            "snippet": { "type": "string" },
            "detected_entities": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "document": {
      "type": "object",
      "required": ["document_id", "source_name", "total_pages", "is_verified_sequence", "fragments"],
      "properties": {
        "document_id": { "type": "string" },
        "source_name": { "type": "string" },
        "total_pages": { "type": "integer", "minimum": 1 },
        "is_verified_sequence": { "type": "boolean" },
        "merge_confidence": { "type": "number" },
        "review_required": { "type": "boolean" },
        "global_summary": { "type": "string" },
        "source_document_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "fragments": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/fragment" }
        }
      },
      "additionalProperties": true
    },
    "edge_score": {
      "type": "object",
      "required": [
        "from_fragment_id",
        "to_fragment_id",
        "score_0_10",
        "decision_status",
        "scorer_type",
        "latency_ms"
      ],
      "properties": {
        "from_fragment_id": { "type": "string" },
        "to_fragment_id": { "type": "string" },
        "score_0_10": { "type": "number", "minimum": 0, "maximum": 10 },
        "reason": { "type": "string" },
        "decision_status": {
          "type": "string",
          "enum": ["auto_merge", "review_required", "reject"]
        },
        "scorer_type": {
          "type": "string",
          "enum": ["heuristic", "llm"]
        },
        "latency_ms": { "type": "number", "minimum": 0 },
        "review_required": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "batch": {
      "type": "object",
      "required": ["batch_id", "generated_at_utc", "documents"],
      "properties": {
        "schema_version": { "type": "string" },
        "batch_id": { "type": "string" },
        "generated_at_utc": { "type": "string" },
        "md_temp_dir": { "type": "string" },
        "scorer_mode": {
          "type": "string",
          "enum": ["heuristic", "llm", "both"]
        },
        "active_scorer": {
          "type": "string",
          "enum": ["heuristic", "llm"]
        },
        "documents": {
          "type": "array",
          "items": { "$ref": "#/$defs/document" }
        },
        "edge_scores": {
          "type": "array",
          "items": { "$ref": "#/$defs/edge_score" }
        }
      },
      "additionalProperties": true
    }
  }
}